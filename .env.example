# =============================================================
# Sintonía UNAM — Variables de entorno
# Copia este archivo como `.env.local` y completa los valores.
# Las variables VITE_* se inyectan en el build del frontend.
# =============================================================

# --- Frontend (seguras de exponer) ---
VITE_SUPABASE_URL=https://knblatuzbgzgnugwkxdp.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Ruta base de Vite. Si el repo de GitHub se llama distinto, ajústalo.
# Ejemplo: VITE_BASE_PATH=/sintonia-unam/
VITE_BASE_PATH=/sintonia-unam/

# =============================================================
# --- BACKEND (NUNCA exponer en frontend) ---
# Estas variables se configuran como SECRETS en Supabase Edge Functions
# (Project Settings → Edge Functions → Secrets).
# NO van en `.env.local`. Aquí sólo como referencia.
# =============================================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
