# =============================================================
# Sintonía UNAM — Variables de entorno
# Copia este archivo como `.env.local` y completa los valores.
# Las variables VITE_* se inyectan en el build del frontend.
# =============================================================

# --- Frontend (seguras de exponer si tienes RLS activo) ---
# Reemplaza estos placeholders con los valores reales en tu .env.local
VITE_SUPABASE_URL=https://<TU_PROYECTO>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Ruta base de Vite. Si el repo de GitHub se llama distinto, ajústalo.
# Ejemplo: VITE_BASE_PATH=/sintonia-unam/
VITE_BASE_PATH=/sintonia-unam/

# =============================================================
# --- BACKEND (NUNCA exponer en frontend) ---
# Estas variables se configuran como SECRETS en Supabase Edge Functions
# (Project Settings → Edge Functions → Secrets).
# NO van en `.env.local`. Aquí sólo como referencia.
# =============================================================
# Estas dos NO necesitas crearlas: Supabase las inyecta automáticamente
# en cada Edge Function. Las dejamos comentadas como referencia.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Estas SÍ las defines tú en Supabase → Project Settings → Edge Functions → Secrets
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
